                  "const responseJson = pm.response.json();",
                  "if (responseJson && responseJson.data && responseJson.data.token) {",
                  "    pm.environment.set(\"authToken\", responseJson.data.token);",
                  "    console.log(\"Auth Token set to:\", responseJson.data.token);",
                  "}"
